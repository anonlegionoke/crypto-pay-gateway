# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/database_name"

# JWT Configuration
JWT_SECRET="your-secret-key-here"
JWT_EXPIRES_IN="24h"

# API Configuration
NEXT_PUBLIC_API_URL="http://localhost:3000"
SOLANA_NETWORK="devnet"
NEXT_PUBLIC_SOLANA_NETWORK="devnet"
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.devnet.solana.com"
NEXT_PUBLIC_USE_REAL_JUPITER_SWAPS="false"
NEXT_PUBLIC_JUPITER_API_URL="https://api.jup.ag"
NEXT_PUBLIC_JUPITER_API_KEY=""

# Security Configuration
NEXT_PUBLIC_CORS_ORIGIN="http://localhost:3000"
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Upstash Rate Limit Backend (required in production for distributed rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Logging Configuration
LOG_LEVEL="info"
NODE_ENV="development"

# Monitoring Configuration
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_ANALYTICS_ID=""

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS="false"
NEXT_PUBLIC_ENABLE_MAINTENANCE_MODE="false" 
